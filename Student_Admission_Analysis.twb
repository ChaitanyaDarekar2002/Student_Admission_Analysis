        <view>
          <datasources>
            <datasource caption='Admission Records (Student_Admission_Records)' name='federated.0qa31w90s5ikam1b5vc0h1sw0bfq' />
          </datasources>
          <datasource-dependencies datasource='federated.0qa31w90s5ikam1b5vc0h1sw0bfq'>
            <column datatype='integer' name='[Age]' role='measure' type='quantitative' />
            <column caption='Total Students' datatype='integer' name='[Calculation_0227326947561472]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='COUNT([Student_Name])' />
            </column>
            <column caption='Average Percentage' datatype='real' name='[Calculation_0227326949236737]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='AVG([Previous_Percentage])' />
            </column>
            <column caption='Pass_Student' datatype='integer' name='[Calculation_0227326949515266]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='COUNT(&#13;&#10;IF [Previous_Percentage] &gt;= 40 THEN [Student_Name]&#13;&#10;END&#13;&#10;)' />
            </column>
            <column caption='Course Applied' datatype='string' name='[Course_Applied]' role='dimension' type='nominal' />
            <column caption='Entrance Exam Score' datatype='integer' name='[Entrance_Exam_Score]' role='measure' type='quantitative' />
            <column caption='Fee Status' datatype='string' name='[Fee_Status]' role='dimension' type='nominal' />
